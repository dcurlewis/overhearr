# Overhearr docker-compose env file.
#
# Copy to `.env.docker` and fill in the two required secrets. They must
# be unique per deployment and never committed.
#
# Generate both at once with:
#   ./scripts/generate-secrets.sh > .env.docker
# or individually:
#   openssl rand -hex 32

# 64-char hex string used to sign session cookies. Required.
SESSION_SECRET=

# 64-char hex string (32 bytes) used to encrypt the Lidarr API key at rest
# in the SQLite DB. Required. Rotating this AFTER initial setup will
# invalidate stored credentials — re-enter them in the UI.
ENCRYPTION_KEY=

# --- Optional ---

# Log verbosity: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Set to true behind nginx/Traefik/Cloudflare so Express trusts X-Forwarded-*.
TRUST_PROXY=false
