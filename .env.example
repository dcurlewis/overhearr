# Overhearr environment configuration
#
# Lidarr is configured via the in-app settings UI on first run, NOT via
# environment variables. Discover sources (ListenBrainz + MusicBrainz) are
# anonymous public APIs and need no configuration. This file is for
# infrastructure-level config only.

# Server
PORT=5056
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database (SQLite). Prisma resolves SQLite relative paths from the schema
# file (prisma/schema.prisma), so `..` walks back to the repo root. In Docker
# this lives under the bind-mounted /config volume.
DATABASE_URL=file:../config/db/overhearr.db

# Session secret (REQUIRED in production — app refuses to start with the default).
# Generate a random 64+ char string, e.g. `openssl rand -hex 32`.
SESSION_SECRET=change-me-to-random-string

# Encryption key for at-rest secrets (Lidarr API key) stored in DB.
# Generate with `openssl rand -hex 32`. REQUIRED in production.
ENCRYPTION_KEY=change-me-to-random-string
