{
  "name": "overhearr",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted music request manager for Lidarr, in the spirit of Overseerr.",
  "license": "MIT",
  "author": "David Curlewis <david@curlewis.co.nz>",
  "homepage": "https://github.com/dcurlewis/overhearr",
  "repository": {
    "type": "git",
    "url": "https://github.com/dcurlewis/overhearr.git"
  },
  "bugs": {
    "url": "https://github.com/dcurlewis/overhearr/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0",
  "scripts": {
    "dev": "tsx watch --clear-screen=false server/index.ts",
    "build": "npm run build:next && npm run build:server",
    "build:next": "next build",
    "build:server": "tsc --project server/tsconfig.json && tsc-alias -p server/tsconfig.json",
    "start": "cross-env NODE_ENV=production node dist/server/index.js",
    "lint": "eslint \"./server/**/*.{ts,tsx}\" \"./src/**/*.{ts,tsx}\" --cache",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run typecheck && npm run lint && npm run test && npm run test:e2e",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.1.3",
    "@prisma/client": "^5.22.0",
    "axios": "^1.6.8",
    "bcrypt": "^5.1.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "lodash.debounce": "^4.0.8",
    "lru-cache": "^11.0.0",
    "next": "^14.2.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.22.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.51.0",
    "swr": "^2.2.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vitest/coverage-v8": "^1.5.0",
    "@vitest/ui": "^1.5.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jsdom": "^27.0.1",
    "msw": "^2.2.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "tailwindcss": "^3.4.0",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^1.5.0"
  }
}
